# The Residentialist — Environment Variables
# Copy this file to .env.local and fill in values

# PostgreSQL connection string (Supabase / Railway / Neon)
DATABASE_URL=postgresql://user:password@host:5432/residentialist

# Path to local pipeline directory (for the import script)
# Mac Mini path:
PIPELINE_ROOT=/Users/Residentialist/.openclaw/workspace/residentialist
